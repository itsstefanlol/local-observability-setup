{
  "uid": "dotnet-nextjs-local-observability",
  "title": "Local Observability - Next.js + .NET + PostgreSQL",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": ".NET Backend Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"dotnet-backend\"}",
          "legendFormat": "backend"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "DB Health",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "backend_db_health_status",
          "legendFormat": "db health"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Slow Queries In Selected Range",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(backend_db_slow_queries_total[$__range]))",
          "legendFormat": "slow queries"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DB Errors In Selected Range",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(backend_db_query_errors_total[$__range]))",
          "legendFormat": "db errors"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Backend HTTP Request Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total{job=\"dotnet-backend\"}[1m])) by (code, action)",
          "legendFormat": "{{action}} - {{code}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Backend DB Query Rate",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(backend_db_queries_total[1m])) by (query_name, status)",
          "legendFormat": "{{query_name}} - {{status}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "DB Query p95 Duration From Backend",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(backend_db_query_duration_seconds_bucket[$__rate_interval])) by (le, query_name))",
          "legendFormat": "{{query_name}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB Connections From Backend Perspective",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "backend_db_active_connections",
          "legendFormat": "active app db connections"
        },
        {
          "expr": "backend_db_max_pool_size",
          "legendFormat": "max pool size"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Container CPU Usage",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{job=\"cadvisor\", container_label_com_docker_compose_service!=\"\", id!=\"/\"}[$__rate_interval]))",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Container Memory Usage",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (container_memory_working_set_bytes{job=\"cadvisor\", container_label_com_docker_compose_service!=\"\", id!=\"/\"})",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 11,
      "type": "table",
      "title": "User Journeys through Traces",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "query": "{ resource.service.name = \"nextjs-frontend\" }",
          "queryType": "traceql",
          "refId": "A",
          "limit": 20,
          "spanLimit": 20,
          "tableType": "traces"
        }
      ],
      "options": {
        "showTraceID": true,
        "showSpanBar": true
      }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Backend Application Logs",
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 36        
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"backend\"} |= \"query_name\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}